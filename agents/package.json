{
  "name": "@policysynth/agents",
  "version": "1.3.180",
  "author": "Robert Bjarnason, Citizens Foundation",
  "repository": {
    "type": "git",
    "url": "https://github.com/CitizensFoundation/policy-synth/tree/main/agents"
  },
  "engines": {
    "node": ">=20.16.0 <21 || >=22.3.0"
  },
  "license": "MIT",
  "devDependencies": {
    "@tsconfig/node20": "^20.1.9",
    "@types/form-data": "^2.5.2",
    "@types/html-to-text": "^9.0.4",
    "@types/lodash": "^4.17.24",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "@types/puppeteer": "^7.0.4",
    "@types/qs": "^6.15.0",
    "@types/winston": "^2.4.4",
    "nodemon": "^3.1.14",
    "typescript": "^5.9.3"
  },
  "files": [
    "ts-out/**/*",
    "src/*.d.ts"
  ],
  "scripts": {
    "prepublishOnly": "npm pack && node repack",
    "publish": "npm pack && node repack && node publish.js https://registry.npmjs.org/",
    "publish_local": "npm pack && node repack && node publish.js http://localhost:4873",
    "test": "npm run test:unit",
    "test:build": "tsc --project ./tsconfig.test.json",
    "test:unit": "npm run test:build && node --test ts-out-test/tests/aiModels/*.test.js ts-out-test/tests/base/*.test.js",
    "createWeaviateRagDocument": "npm run build;cp -R src/rag/vectorstore/schemas ts-out/vectorstore/;node ts-out/rag/vectorstore/tools/createRagDocument.js",
    "createWeaviateRagChunk": "npm run build;cp -R src/rag/vectorstore/schemas ts-out/vectorstore/;node ts-out/rag/vectorstore/tools/createRagChunk.js",
    "destroyWeaviateRagChunk": "node ts-out/rag/vectorstore/tools/destroyRagChunk.js",
    "destroyWeaviateRagDocument": "node ts-out/rag/vectorstore/tools/destroyRagDocument.js",
    "build": "tsc --project ./ --outDir ./ts-out",
    "start": "nodemon -q ts-out/queue.js",
    "watch-start": "tsc --project ./ --outDir ./ts-out -w & node ts-out/queue.js"
  },
  "cacheDirectories": [
    "node_modules"
  ],
  "type": "module",
  "dependencies": {
    "@airbrake/node": "^2.1.9",
    "@anthropic-ai/bedrock-sdk": "^0.29.0",
    "@anthropic-ai/sdk": "^0.91.1",
    "@anthropic-ai/vertex-sdk": "^0.16.0",
    "@azure/identity": "^4.13.1",
    "@google-cloud/vertexai": "^1.12.0",
    "@google/genai": "^1.50.1",
    "@google/generative-ai": "^0.24.1",
    "@mendable/firecrawl-js": "^4.20.0",
    "axios": "1.15.2",
    "bullmq": "^5.76.2",
    "chalk": "^5.5.2",
    "colors": "^1.4.0",
    "discord.js": "^14.26.3",
    "form-data": "^4.0.5",
    "glob": "^13.0.6",
    "google-auth-library": "^10.6.2",
    "googleapis": "^171.4.0",
    "html-to-text": "^9.0.5",
    "ioredis": "^5.10.1",
    "jsonrepair": "^3.14.0",
    "lodash": "^4.18.1",
    "mammoth": "^1.12.0",
    "node-fetch": "^3.3.2",
    "openai": "^6.34.0",
    "p-limit": "^7.3.0",
    "pdf-parse": "^2.4.5",
    "pg": "^8.20.0",
    "puppeteer": "^24.42.0",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "qs": "^6.15.1",
    "sequelize": "^6.37.8",
    "tar": "^7.5.13",
    "tiktoken": "^1.0.22",
    "tldts": "^7.0.28",
    "weaviate-ts-client": "^2.2.0",
    "winston": "^3.19.0",
    "ws": "^8.18.2"
  },
  "overrides": {
    "@xmldom/xmldom": "0.8.13",
    "axios": {
      "follow-redirects": "^1.16.0"
    },
    "basic-ftp": "5.3.0",
    "cosmiconfig": {
      "js-yaml": "^4.1.1"
    },
    "fast-xml-parser": "5.7.2",
    "minimatch@3.1.5": {
      "brace-expansion": "^1.1.14"
    },
    "protobufjs": "7.5.5",
    "uuid": "14.0.0"
  }
}
